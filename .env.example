# Ordner mit den Produktfotos
INPUT_FOLDER=./input

# Dateiname-Keyword für Trennbilder (Groß-/Kleinschreibung egal)
SEPARATOR_KEYWORD=trenner

# --- Zugangsschutz (empfohlen!) ---
# Ohne diesen Wert ist die App offen für jeden der die URL kennt.
# Setze ein starkes Passwort, z.B.: openssl rand -hex 16
ACCESS_TOKEN=dein-geheimes-passwort

# --- KI (Google Gemini — kostenlos) ---
GEMINI_API_KEY=AIza...

# --- Shopify API ---
# SHOPIFY_SHOP=dein-shop.myshopify.com
# SHOPIFY_TOKEN=shpat_...
